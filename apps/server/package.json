{
  "name": "@feed-plan/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "db:migrate": "pnpm --filter @feed-plan/db db:migrate",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@feed-plan/db": "workspace:*",
    "@feed-plan/shared": "workspace:*",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/testing": "^11.1.26",
    "@swc/core": "^1.15.41",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@feed-plan/typescript-config": "workspace:*",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  }
}
