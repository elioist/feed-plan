# ── 后端服务 ──
PORT=3000
NODE_ENV=development
UPLOAD_DIR=uploads

# ── 数据库 ──
# 本机直连 docker-compose 暴露的 postgres：localhost:55432
# （compose 内部 server 容器会用服务名 db:5432，由 compose 注入，无需改这里）
DATABASE_URL=postgres://postgres:postgres@localhost:55432/feed_plan

# ── JWT ──
# 生产务必改成至少 16 位的随机字符串
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# ── 种子初始账号（仅首次 seed 使用，初始密码不可硬编码进代码）──
SEED_CHEF_USERNAME=chef
SEED_CHEF_PASSWORD=set-a-chef-password
SEED_DINER_USERNAME=diner
SEED_DINER_PASSWORD=set-a-diner-password
