{
  "name": "feed-plan",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "db:up": "docker compose up -d db",
    "dev": "pnpm db:up && turbo run dev",
    "dev:admin": "turbo run dev --filter=@feed-plan/admin-web",
    "dev:server": "pnpm db:up && turbo run dev --filter=@feed-plan/server",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "prettier": "@feed-plan/prettier-config",
  "devDependencies": {
    "@feed-plan/eslint-config": "workspace:*",
    "@feed-plan/prettier-config": "workspace:*",
    "@feed-plan/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
